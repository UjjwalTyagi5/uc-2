# Copy this file to `.env` (same folder as run_pipeline_local.py) and fill in
# every blank below. Quotes are not required. Lines starting with `#` are ignored.
#
# After editing, run:    python run_pipeline_local.py
# Single PR test:        set PR_FILTER and leave EXCEL_PATH blank.

# ─── Source DB (on-prem RAS, reached via VPN typically) ──────────────────────
SRC_DB_HOST=
SRC_DB_PORT=1433
SRC_DB_DATABASE=
SRC_DB_USERNAME=
SRC_DB_PASSWORD=
SRC_DB_DRIVER=ODBC Driver 17 for SQL Server

# ─── Target DB (Azure SQL) ───────────────────────────────────────────────────
TGT_DB_HOST=
TGT_DB_PORT=1433
TGT_DB_DATABASE=
TGT_DB_USERNAME=
TGT_DB_PASSWORD=
TGT_DB_DRIVER=ODBC Driver 18 for SQL Server

# ─── Azure OpenAI ────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_LLM_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-large

# ─── Azure Blob Storage ──────────────────────────────────────────────────────
AZURE_BLOB_ACCOUNT_URL=https://<account>.blob.core.windows.net
AZURE_BLOB_CONTAINER=procurement
# Auth — fill ONE of the two; if both are blank, the runner falls back to
# DefaultAzureCredential (works if you have done `az login` on this machine):
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_ACCOUNT_KEY=

# ─── Pinecone ────────────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=ras-quotations
PINECONE_NAMESPACE=procurement
# Used only when the index does not exist yet — ignored if it already exists.
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_METRIC=dotproduct

# ─── Pipeline knobs (conservative defaults for an 8 vCPU / 32 GB VM) ─────────
PARALLEL_WORKERS=2
CLS_PARALLEL_SOURCES=3
EXT_PARALLEL_SOURCES=1
MAX_DB_CONNECTIONS=30
BATCH_LIMIT=0
MAX_CONTENT_CHARS=80000
PINECONE_TOP_K=10

# ─── What to process — set EITHER EXCEL_PATH or PR_FILTER ────────────────────
# Excel column 1 (or set EXCEL_COLUMN) holds PURCHASE_REQ_NO. Header row OK.
EXCEL_PATH=
EXCEL_SHEET=
EXCEL_COLUMN=
# Single-PR override (takes priority over EXCEL_PATH):
PR_FILTER=
