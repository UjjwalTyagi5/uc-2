# Copy this file to `.env` (same folder as run_pipeline_local.py) and fill in
# every blank below. Quotes are not required. Lines starting with `#` are ignored.
#
# After editing, run:    python run_pipeline_local.py
# Single PR test:        set PR_FILTER and leave EXCEL_PATH blank.

# ─── Source DB (on-prem RAS, reached via VPN typically) ──────────────────────
SRC_DB_HOST=
SRC_DB_PORT=1433
SRC_DB_DATABASE=
SRC_DB_USERNAME=
SRC_DB_PASSWORD=
SRC_DB_DRIVER=ODBC Driver 17 for SQL Server

# ─── Target DB (Azure SQL) ───────────────────────────────────────────────────
TGT_DB_HOST=
TGT_DB_PORT=1433
TGT_DB_DATABASE=
TGT_DB_USERNAME=
TGT_DB_PASSWORD=
TGT_DB_DRIVER=ODBC Driver 18 for SQL Server

# ─── Azure OpenAI / Azure AI Foundry ─────────────────────────────────────────
# AZURE_OPENAI_ENDPOINT format:
#   • Standard Azure OpenAI:  https://<resource>.openai.azure.com/
#   • Azure AI Foundry:       https://<resource>.services.ai.azure.com/
#                             (use the "Target URI" shown in the Foundry portal)
# AZURE_OPENAI_LLM_DEPLOYMENT = the deployment NAME you created in the portal
# (NOT the underlying model id). Same for the embedding deployment.
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_LLM_DEPLOYMENT=
AZURE_OPENAI_EMBED_DEPLOYMENT=

# Optional — set only if your deployment needs sampling control AND supports
# it. Newer reasoning models (gpt-5.x, o-series) REJECT temperature; leave
# this blank for them. For classic gpt-4o / gpt-4o-mini, "0" gives deterministic
# output and is recommended for extraction work.
AZURE_OPENAI_TEMPERATURE=

# Optional — override the model identifier sent to the API. Almost always
# unnecessary because azure_deployment alone resolves the model server-side.
AZURE_OPENAI_LLM_MODEL=
AZURE_OPENAI_EMBED_MODEL=

# ─── Azure Blob Storage ──────────────────────────────────────────────────────
AZURE_BLOB_ACCOUNT_URL=https://<account>.blob.core.windows.net
AZURE_BLOB_CONTAINER=procurement
# Auth — fill ONE of the two; if both are blank, the runner falls back to
# DefaultAzureCredential (works if you have done `az login` on this machine):
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_ACCOUNT_KEY=

# ─── Pinecone ────────────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=ras-quotations
PINECONE_NAMESPACE=procurement
# Used only when the index does not exist yet — ignored if it already exists.
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_METRIC=dotproduct

# ─── Pipeline knobs (conservative defaults for an 8 vCPU / 32 GB VM) ─────────
PARALLEL_WORKERS=2
CLS_PARALLEL_SOURCES=3
EXT_PARALLEL_SOURCES=1
MAX_DB_CONNECTIONS=30
BATCH_LIMIT=0
PINECONE_TOP_K=10

# ─── Character / page limits — raise for long quotation docs ─────────────────
# MAX_CONTENT_CHARS  = Stage 2 overall ceiling for extracted text per file
# CLS_MAX_CHARS      = Stage 4 chars sent to the classification LLM (≈4 chars/token)
# EXT_MAX_CHARS      = Stage 5 chars sent to the extraction LLM (0 = no limit, risky)
# CLS_MAX_PAGES_VISION = Stage 4 PDF pages rendered to images for vision fallback
# EXT_MAX_PAGES      = Stage 5 PDF pages rendered per extraction
# EXT_MAX_IMAGES     = Stage 5 hard cap on images per LLM call (Azure caps at ~50)
MAX_CONTENT_CHARS=80000
CLS_MAX_CHARS=24000
EXT_MAX_CHARS=50000
CLS_MAX_PAGES_VISION=5
EXT_MAX_PAGES=20
EXT_MAX_IMAGES=50

# ─── What to process — set EITHER EXCEL_PATH or PR_FILTER ────────────────────
# Excel column 1 (or set EXCEL_COLUMN) holds PURCHASE_REQ_NO. Header row OK.
EXCEL_PATH=
EXCEL_SHEET=
EXCEL_COLUMN=
# Single-PR override (takes priority over EXCEL_PATH):
PR_FILTER=
