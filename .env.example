# On-prem SQL Server (source for purchase_sync ETL)
ONPREM_SERVER=
ONPREM_DB=
ONPREM_USER=
ONPREM_PASS=

# Azure SQL Database (target)
AZURE_SERVER=
AZURE_DB=
AZURE_USER=
AZURE_PASS=

# Control and status table names on Azure DB
SYNC_CONTROL_TABLE=etl_sync_control
SYNC_STATUS_TABLE=etl_sync_status

# ODBC driver — optional, auto-detected if not set
# Override only if auto-detection picks the wrong one:
# ODBC_DRIVER=ODBC Driver 18 for SQL Server

# Rows fetched from on-prem per round-trip (increase for faster reads on large tables)
BATCH_SIZE=100000

# Rows per Azure executemany call — keep small (1000-5000) if tables have
# nvarchar(max)/varchar(max) columns which force pyodbc into slow SQLParamData mode
AZURE_BATCH_SIZE=2000

# Parallel workers per table — each worker opens its own source + Azure connection
# and inserts an independent slice of rows. Increase for faster sync on large tables.
PARALLEL_WORKERS=4

# -----------------------------------------------------------------------
# attachment_blob_sync — Azure Blob Storage
# -----------------------------------------------------------------------
BLOB_ACCOUNT_URL=https://<account>.blob.core.windows.net
BLOB_ACCOUNT_KEY=
BLOB_CONTAINER_NAME=

# -----------------------------------------------------------------------
# Azure OpenAI — document classification (file_classifier)
# -----------------------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_MINI_DEPLOYMENT_NAME=gpt-4o-mini
CONFIDENCE_THRESHOLD=0.75
MAX_CONTENT_TOKENS=6000
