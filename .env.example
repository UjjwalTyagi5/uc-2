# On-prem SQL Server (source)
ONPREM_SERVER=
ONPREM_DB=
ONPREM_USER=
ONPREM_PASS=

# Azure SQL Database (target)
AZURE_SERVER=
AZURE_DB=
AZURE_USER=
AZURE_PASS=

# Control and status table names on Azure DB
SYNC_CONTROL_TABLE=etl_sync_control
SYNC_STATUS_TABLE=etl_sync_status

# ODBC driver name — check installed drivers with: odbcad32.exe (Windows)
# Use "ODBC Driver 17 for SQL Server" or "ODBC Driver 18 for SQL Server"
ODBC_DRIVER=ODBC Driver 17 for SQL Server
