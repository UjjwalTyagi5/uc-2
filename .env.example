# On-prem SQL Server (source for purchase_sync ETL)
ONPREM_SERVER=
ONPREM_DB=
ONPREM_USER=
ONPREM_PASS=

# Azure SQL Database (target)
AZURE_SERVER=
AZURE_DB=
AZURE_USER=
AZURE_PASS=

# Control and status table names on Azure DB
SYNC_CONTROL_TABLE=etl_sync_control
SYNC_STATUS_TABLE=etl_sync_status

# ODBC driver — optional, auto-detected if not set
# Override only if auto-detection picks the wrong one:
# ODBC_DRIVER=ODBC Driver 18 for SQL Server

# Rows fetched from on-prem per round-trip (increase for faster reads on large tables)
BATCH_SIZE=100000

# Rows per Azure executemany call — keep small (1000-5000) if tables have
# nvarchar(max)/varchar(max) columns which force pyodbc into slow SQLParamData mode
AZURE_BATCH_SIZE=2000

# Parallel workers per table — each worker opens its own source + Azure connection
# and inserts an independent slice of rows. Increase for faster sync on large tables.
PARALLEL_WORKERS=4

# -----------------------------------------------------------------------
# attachment_blob_sync — Azure Blob Storage
# -----------------------------------------------------------------------
BLOB_ACCOUNT_URL=https://<account>.blob.core.windows.net
BLOB_ACCOUNT_KEY=
BLOB_CONTAINER_NAME=

# -----------------------------------------------------------------------
# Azure OpenAI — document classification (file_classifier)
# -----------------------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_MINI_DEPLOYMENT_NAME=gpt-4o-mini
CONFIDENCE_THRESHOLD=0.75
MAX_CONTENT_TOKENS=6000

# -----------------------------------------------------------------------
# Azure OpenAI — pipeline stages (CLASSIFICATION, METADATA_EXTRACTION)
# -----------------------------------------------------------------------
# Chat/completion model used by the LLM stages
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# API version for the pipeline LLM calls
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Quotation extraction tuning (all optional)
# EXTRACTION_MAX_PAGES=20
# EXTRACTION_LLM_TEMPERATURE=0
# EXTRACTION_LLM_MAX_TOKENS=16000
# LLM_MAX_RETRIES=3
# LLM_RETRY_BASE_DELAY=5.0

# -----------------------------------------------------------------------
# Azure OpenAI — EMBEDDINGS stage (text-embedding-3-large)
# -----------------------------------------------------------------------
# Credentials: reuses AZURE_OPENAI_API_KEY and AZURE_OPENAI_ENDPOINT above.
# Only set these if your embedding deployment is on a different Azure OpenAI resource:
# AZURE_OPENAI_EMBEDDING_ENDPOINT=https://<other-resource>.openai.azure.com/
# AZURE_OPENAI_EMBEDDING_API_KEY=

# Deployment name for the embedding model
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Output vector size (max 3072 for text-embedding-3-large)
# Must match the dimension your Pinecone index was created with
EMBEDDING_DIMENSIONS=3072

# Number of texts sent to the embedding API per request (default 100)
# EMBEDDING_BATCH_SIZE=100

# -----------------------------------------------------------------------
# Pinecone — vector store for quotation item embeddings
# -----------------------------------------------------------------------
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# Similarity search tuning (all optional)
# Number of nearest neighbours returned per query
# PINECONE_TOP_K=10

# Minimum cosine similarity score to include a result (0.0 – 1.0)
# PINECONE_THRESHOLD=0.75

# Vectors sent to Pinecone per upsert request (default 100)
# PINECONE_UPSERT_BATCH=100
