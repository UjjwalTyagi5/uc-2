# ── async helper ──────────────────────────────────────────────────────────────

def _run_async(coro):
    try:
        loop = asyncio.get_event_loop()
        if loop.is_running():
            import concurrent.futures
            with concurrent.futures.ThreadPoolExecutor(max_workers=1) as pool:
                fut = pool.submit(asyncio.run, coro)
                return fut.result()
        return loop.run_until_complete(coro)
    except RuntimeError:
        return asyncio.run(coro)


# ── blob connector helpers (same pattern as File Trigger) ─────────────────────

def _fetch_blob_connectors() -> list[str]:
    try:
        from agentcore.services.database.utils import get_db
        from agentcore.api.connector_catalogue import ConnectorCatalogue

        async def _inner():
            async for session in get_db():
                rows = await session.execute(
                    __import__("sqlalchemy").select(ConnectorCatalogue).where(
                        ConnectorCatalogue.connector_type == "azure_blob"
                    )
                )
                return rows.scalars().all()

        items = _run_async(_inner()) or []
        return [f"{c.connector_name} | azure_blob | {c.id}" for c in items]
    except Exception:
        return []


def _get_blob_config(connector_value: str) -> dict | None:
    try:
        parts = connector_value.split(" | ")
        connector_id = parts[-1].strip()

        from agentcore.services.database.utils import get_db
        from agentcore.api.connector_catalogue import ConnectorCatalogue
        from agentcore.services.security.encryption import decrypt_value
        import sqlalchemy

        async def _inner():
            async for session in get_db():
                row = await session.get(ConnectorCatalogue, connector_id)
                if not row:
                    return None
                cfg = row.connector_config or {}
                decrypted = {}
                for k, v in cfg.items():
                    try:
                        decrypted[k] = decrypt_value(v) if isinstance(v, str) else v
                    except Exception:
                        decrypted[k] = v
                return decrypted

        return _run_async(_inner())
    except Exception:
        return None


# ── text extraction helpers ───────────────────────────────────────────────────

def _extract_text(path: Path, max_chars: int = 6000) -> str:
    suffix = path.suffix.lower()
    try:
        if suffix == ".pdf":
            import fitz
            doc = fitz.open(str(path))
            return "\n".join(p.get_text() for p in doc)[:max_chars]
        if suffix in (".xlsx", ".xls"):
            import openpyxl
            wb = openpyxl.load_workbook(str(path), read_only=True, data_only=True)
            parts = []
            for ws in wb.worksheets:
                for row in ws.iter_rows(values_only=True):
                    line = "\t".join(str(c) for c in row if c is not None)
                    if line.strip():
                        parts.append(line)
            return "\n".join(parts)[:max_chars]
        if suffix == ".docx":
            from docx import Document
            doc = Document(str(path))
            return "\n".join(p.text for p in doc.paragraphs if p.text.strip())[:max_chars]
        if suffix == ".csv":
            return path.read_text(errors="ignore")[:max_chars]
        if suffix in (".png", ".jpg", ".jpeg", ".bmp", ".tiff"):
            return f"[image file: {path.name}]"
        return path.read_text(errors="ignore")[:max_chars]
    except Exception as exc:
        return f"[extraction error: {exc}]"


# ── transient retry helpers ───────────────────────────────────────────────────

_TRANSIENT_KEYWORDS = [
    "connection reset", "timeout", "throttl", "resource limit",
    "broken pipe", "transport-level", "login failed", "tcp",
]

def _is_transient(exc: Exception) -> bool:
    return any(k in str(exc).lower() for k in _TRANSIENT_KEYWORDS)

def _connect(cs: str, retries: int = 3, base_delay: float = 2.0) -> pyodbc.Connection:
    for attempt in range(retries + 1):
        try:
            return pyodbc.connect(cs, timeout=30)
        except Exception as exc:
            if not _is_transient(exc) or attempt == retries:
                raise
            time.sleep(base_delay * (2 ** attempt) * (1 + random.random() * 0.2))


# ── main component ────────────────────────────────────────────────────────────

class PipelineStage123Node(Node):
    display_name = "Pipeline Stage 1-3"
    description = (
        "Stage 1: Ingestion (ras_tracker). Stage 2: Downloads attachments from on-prem SQL "
        "Server. Stage 3: Uploads to Azure Blob via Connectors Catalogue. "
        "Outputs a single Data object: .text = file batch text for Prompt Template, "
        ".data = context dict for Stage 4-8."
    )
    icon = "Database"
    name = "PipelineStage123Node"

    inputs = [
        MessageInput(
            name="trigger",
            display_name="Trigger",
            info="Connect Chat Input or any trigger here.",
            required=False,
        ),
        DataInput(
            name="source_connection",
            display_name="Source DB (On-Prem)",
            info="Connection Config from the on-prem Database Connector.",
        ),
        DataInput(
            name="target_connection",
            display_name="Target DB (Azure SQL)",
            info="Connection Config from the Azure SQL Database Connector.",
        ),
        DropdownInput(
            name="blob_connector",
            display_name="Azure Blob Connector",
            options=[],
            refresh_button=True,
            real_time_refresh=True,
            info="Select the Azure Blob connector from the Connectors Catalogue.",
        ),
        MessageTextInput(
            name="pr_no_filter",
            display_name="PR No (blank = all pending)",
            value="",
            required=False,
        ),
        IntInput(name="limit", display_name="Max PRs", value=10),
        MessageTextInput(name="az_schema", display_name="Azure Schema", value="ras_procurement", advanced=True),
        MessageTextInput(name="src_schema", display_name="Source Schema", value="ras_attachments", advanced=True),
        IntInput(name="max_chars", display_name="Max chars per file", value=6000, advanced=True),
    ]

    outputs = [
        Output(
            display_name="Pipeline Data",
            name="pipeline_data",
            method="build_pipeline_data",
            types=["Data"],
        ),
    ]

    # ── refresh blob connector options ────────────────────────────────────────

    def update_build_config(self, build_config, field_value, field_name=None):
        if field_name in ("blob_connector", None):
            options = _fetch_blob_connectors()
            build_config["blob_connector"]["options"] = options or ["(no blob connectors found)"]
        return build_config

    # ── connection string helpers ──────────────────────────────────────────────

    def _src_conn_str(self) -> str:
        d = (self.source_connection.data or {}) if self.source_connection else {}
        driver = d.get("driver", "ODBC Driver 18 for SQL Server")
        server = d.get("host", d.get("server", ""))
        port   = d.get("port", 1433)
        db     = d.get("database_name", d.get("database", ""))
        user   = d.get("username", "")
        pwd    = d.get("password", "")
        return (
            f"DRIVER={{{driver}}};SERVER={server},{port};"
            f"DATABASE={db};UID={user};PWD={pwd};TrustServerCertificate=yes;"
        )

    def _tgt_conn_str(self) -> str:
        d = (self.target_connection.data or {}) if self.target_connection else {}
        driver = d.get("driver", "ODBC Driver 18 for SQL Server")
        server = d.get("host", d.get("server", ""))
        port   = d.get("port", 1433)
        db     = d.get("database_name", d.get("database", ""))
        user   = d.get("username", "")
        pwd    = d.get("password", "")
        return (
            f"DRIVER={{{driver}}};SERVER={server},{port};"
            f"DATABASE={db};UID={user};PWD={pwd};TrustServerCertificate=yes;"
        )

    # ── stage 1: upsert ras_tracker ───────────────────────────────────────────

    def _stage1(self, tgt_cs: str, pr_no: str) -> None:
        az = self.az_schema
        conn = _connect(tgt_cs)
        cur  = conn.cursor()
        cur.execute(f"""
            MERGE {az}.ras_tracker AS tgt
            USING (SELECT ? AS pr_no) AS src ON tgt.purchase_req_no = src.pr_no
            WHEN NOT MATCHED THEN
                INSERT (purchase_req_no, current_stage_fk, created_at, updated_at)
                VALUES (?, 1, GETUTCDATE(), GETUTCDATE())
            WHEN MATCHED THEN
                UPDATE SET updated_at = GETUTCDATE();
        """, pr_no, pr_no)
        conn.commit()
        conn.close()
        self.log(f"[Stage 1] ras_tracker upserted for PR={pr_no}")

    # ── stage 2: download attachments from on-prem ────────────────────────────

    def _stage2(self, src_cs: str, pr_no: str, work_dir: Path) -> list[dict]:
        src = self.src_schema
        conn = _connect(src_cs)
        cur  = conn.cursor()

        if pr_no:
            cur.execute(f"""
                SELECT d.ATTACHMENT_ID, d.PURCHASE_REQ_NO, d.FILE_NAME,
                       d.ATTACHED_FILE, a.DOC_ID
                FROM {src}.RAS_ATTACHMENT_DOCUMENTS d
                JOIN {src}.RAS_ATTACHMENTS a ON a.ATTACHMENT_ID = d.ATTACHMENT_ID
                WHERE d.PURCHASE_REQ_NO = ?
            """, pr_no)
        else:
            cur.execute(f"""
                SELECT TOP {self.limit} d.ATTACHMENT_ID, d.PURCHASE_REQ_NO, d.FILE_NAME,
                       d.ATTACHED_FILE, a.DOC_ID
                FROM {src}.RAS_ATTACHMENT_DOCUMENTS d
                JOIN {src}.RAS_ATTACHMENTS a ON a.ATTACHMENT_ID = d.ATTACHMENT_ID
                ORDER BY d.PURCHASE_REQ_NO
            """)

        rows = cur.fetchall()
        conn.close()

        files = []
        for row in rows:
            att_id, pr, fname, blob, doc_id = row
            safe_pr = pr.replace("/", "_").replace("\\", "_")
            dest = work_dir / safe_pr / fname
            dest.parent.mkdir(parents=True, exist_ok=True)
            dest.write_bytes(bytes(blob))
            files.append({
                "attachment_id": att_id,
                "pr_no": pr,
                "file_name": fname,
                "doc_id": doc_id,
                "local_path": str(dest),
            })
            self.log(f"[Stage 2] Downloaded {fname} for PR={pr}")

        return files

    # ── stage 3: upload to azure blob ─────────────────────────────────────────

    def _stage3(self, files: list[dict], work_dir: Path) -> None:
        cfg = _get_blob_config(self.blob_connector or "")
        if not cfg:
            self.log("[Stage 3] No blob connector config — skipping upload")
            return

        account_url    = cfg.get("account_url", "")
        container_name = cfg.get("container_name", "")

        from azure.identity import DefaultAzureCredential
        from azure.storage.blob import BlobServiceClient

        credential   = DefaultAzureCredential()
        blob_service = BlobServiceClient(account_url=account_url, credential=credential)
        container    = blob_service.get_container_client(container_name)

        for f in files:
            local = Path(f["local_path"])
            blob_path = str(local.relative_to(work_dir)).replace("\\", "/")
            with open(local, "rb") as fh:
                container.upload_blob(blob_path, fh, overwrite=True)
            self.log(f"[Stage 3] Uploaded {blob_path}")

    # ── run all 3 stages (cached) ──────────────────────────────────────────────

    def _execute(self) -> dict:
        if hasattr(self, "_cached_result"):
            return self._cached_result

        src_cs = self._src_conn_str()
        tgt_cs = self._tgt_conn_str()
        work_dir = Path(tempfile.mkdtemp(prefix="pipeline_"))

        pr_filter = (self.pr_no_filter or "").strip()
        pr_nos = [pr_filter] if pr_filter else self._fetch_pending_prs(tgt_cs)

        all_files: list[dict] = []
        for pr_no in pr_nos:
            self._stage1(tgt_cs, pr_no)
            files = self._stage2(src_cs, pr_no, work_dir)
            all_files.extend(files)

        if all_files:
            self._stage3(all_files, work_dir)

        # Build file batch text
        sections = []
        for f in all_files:
            text = _extract_text(Path(f["local_path"]), self.max_chars)
            sections.append(f"=== FILE: {f['file_name']} (PR: {f['pr_no']}) ===\n{text}")
        file_batch_text = "\n\n".join(sections) if sections else "(no files found)"

        self._cached_result = {
            "file_batch_text": file_batch_text,
            "pr_nos": pr_nos,
            "az_schema": self.az_schema,
            "files": all_files,
        }
        return self._cached_result

    def _fetch_pending_prs(self, tgt_cs: str) -> list[str]:
        az = self.az_schema
        conn = _connect(tgt_cs)
        cur  = conn.cursor()
        cur.execute(f"""
            SELECT TOP {self.limit} purchase_req_no
            FROM {az}.ras_tracker
            WHERE current_stage_fk < 8
            ORDER BY created_at ASC
        """)
        prs = [r[0] for r in cur.fetchall()]
        conn.close()
        return prs

    # ── single combined output ────────────────────────────────────────────────

    def build_pipeline_data(self) -> Data:
        result = self._execute()
        return Data(
            text=result["file_batch_text"],   # Prompt Template reads this via {pr_batch}
            data={
                "pr_nos":    result["pr_nos"],
                "az_schema": result["az_schema"],
                "files":     result["files"],
            },
        )
